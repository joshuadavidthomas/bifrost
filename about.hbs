<html lang="en">

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bifrost third-party licenses</title>
    <style>
      @media (prefers-color-scheme: dark) {
        body {
          background: #333;
          color: white;
        }
        a {
          color: skyblue;
        }
      }
      .container {
        font-family: sans-serif;
        max-width: 800px;
        margin: 0 auto;
      }
      .intro {
        text-align: center;
      }
      .licenses-list {
        list-style-type: none;
        margin: 0;
        padding: 0;
      }
      .license-used-by {
        margin-top: -10px;
      }
      .license-text {
        max-height: 200px;
        overflow-y: scroll;
        white-space: pre-wrap;
      }
    </style>
  </head>

  <body>
    <main class="container">
      <div class="intro">
        <h1>Bifrost third-party licenses</h1>
        <p>
          This report covers Rust dependencies incorporated into official
          Bifrost command-line binaries and Python wheels. It is generated from
          the locked default plus
          <code>python</code>
          feature graph across all release targets. Development-only
          dependencies and the optional
          <code>nlp</code>
          feature are outside this artifact report.
        </p>
        <p>
          Bifrost's own terms are in
          <code>LICENSE.md</code>. See
          <code>SOURCE.md</code>
          for the corresponding source revision. Vendored C libraries and data
          files whose licenses are not represented by their Rust wrapper's Cargo
          metadata are covered by
          <code>SUPPLEMENTAL_THIRD_PARTY_NOTICES.txt</code>.
        </p>
      </div>

      <h2>Overview of licenses:</h2>
      <ul class="licenses-overview">
        {{#each overview}}
          <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
        {{/each}}
      </ul>

      <h2>All license text:</h2>
      <ul class="licenses-list">
        {{#each licenses}}
          <li class="license">
            <h3 id="{{id}}">{{name}}</h3>
            <h4>Used by:</h4>
            <ul class="license-used-by">
              {{#each used_by}}
                {{#if crate.repository}}
                  <li><a href="{{crate.repository}}">{{crate.name}}
                      {{crate.version}}</a></li>
                {{else}}
                  <li><a
                      href="https://crates.io/crates/{{crate.name}}"
                    >{{crate.name}} {{crate.version}}</a></li>
                {{/if}}
              {{/each}}
            </ul>
            <pre class="license-text">{{text}}</pre>
          </li>
        {{/each}}
      </ul>
    </main>
  </body>

</html>