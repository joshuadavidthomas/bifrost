{
  "name": "bifrost-vscode",
  "displayName": "Bifrost: Multi-Language LSP & MCP Server",
  "description": "Tree-sitter-backed code intelligence for definitions, references, symbols, hierarchy, rename, diagnostics, and MCP workflows.",
  "version": "0.0.1",
  "bifrost": {
    "binaryVersion": "0.6.8",
    "archiveSha256": {
      "aarch64-pc-windows-msvc": "4683b6f5ef9ff46fd5c71294e77d51a1dd8eee37a967214349b66790ca81f89c",
      "aarch64-unknown-linux-gnu": "0287481cd86f2db20b8af7603954ee60feb8baf2e56deeb3eb64943fb1e2fd65",
      "universal-apple-darwin": "8a9a27bba5d8947d5c9e167988c3c222bb217d15b551d86e88277990b544dbc1",
      "x86_64-pc-windows-msvc": "cc774ee4d771a9979a0937697c13139021eb8a9ae1f6e92281da7d800aee8202",
      "x86_64-unknown-linux-gnu": "fb4846273793accadaff28761caf64fe9e7a1b78737bcfd69e9a7bc9f3356b7d"
    }
  },
  "publisher": "brokk",
  "homepage": "https://brokk.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/BrokkAi/bifrost"
  },
  "license": "LGPL-3.0-or-later",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:java",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:rust",
    "onLanguage:go",
    "onLanguage:python",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:csharp",
    "onLanguage:php",
    "onLanguage:scala"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bifrost",
      "properties": {
        "bifrost.launchMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "bundled",
            "path"
          ],
          "enumDescriptions": [
            "Auto-detect a configured path, bundled binary, local development binary, or PATH binary.",
            "Use the Bifrost binary bundled with the extension.",
            "Use bifrost.serverPath, or the bifrost command on PATH when no path is configured."
          ],
          "description": "How to start the Bifrost language server."
        },
        "bifrost.serverPath": {
          "type": "string",
          "default": "bifrost",
          "description": "Path to the bifrost binary, or the command name to resolve on PATH."
        },
        "bifrost.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose Bifrost LSP request and notification tracing."
        },
        "bifrost.slowRequestMs": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Log Bifrost LSP requests and notifications that take at least this many milliseconds."
        },
        "bifrost.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command-line arguments appended when launching the Bifrost LSP server."
        },
        "bifrost.roots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Workspace-relative or absolute directories to index instead of the full VS Code workspace. Empty means use VS Code workspace folders."
        },
        "bifrost.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Workspace-relative or absolute files or directories to exclude from Bifrost indexing and LSP lookups."
        }
      }
    },
    "commands": [
      {
        "command": "bifrost.startServer",
        "title": "Bifrost: Start Language Server"
      },
      {
        "command": "bifrost.stopServer",
        "title": "Bifrost: Stop Language Server"
      },
      {
        "command": "bifrost.restartServer",
        "title": "Bifrost: Restart Language Server"
      },
      {
        "command": "bifrost.copyMcpConfig",
        "title": "Bifrost: Copy MCP Config"
      },
      {
        "command": "bifrost.openMcpSetup",
        "title": "Bifrost: Open MCP Setup"
      },
      {
        "command": "bifrost.showOutput",
        "title": "Bifrost: Show Output"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "compile:test": "tsc -p tsconfig.test.json",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "npm run lint && npm run compile && npm run test:unit",
    "test:unit": "npm run compile:test && node --test test/*.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "tar": "^7.5.19",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "^0.19.0",
    "typescript": "^5.4.0"
  }
}
