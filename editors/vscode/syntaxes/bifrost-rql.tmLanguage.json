{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bifrost Rune Query Language",
  "scopeName": "source.bifrost-rql",
  "patterns": [
    {
      "match": "(^|\\s)(;.*$)",
      "captures": {
        "2": {
          "name": "comment.line.semicolon.bifrost-rql"
        }
      }
    },
    {
      "name": "meta.regex-predicate.bifrost-rql",
      "match": "(\\(|:)(?:\\s*)((?:name|text)/regex)(?:\\s*)(\\\")((?:\\\\.|[^\\\"\\\\])*)(\\\")",
      "captures": {
        "1": {
          "name": "punctuation.section.parens.begin.bifrost-rql"
        },
        "2": {
          "name": "support.function.predicate.bifrost-rql"
        },
        "3": {
          "name": "punctuation.definition.string.begin.bifrost-rql"
        },
        "4": {
          "name": "string.regexp.bifrost-rql"
        },
        "5": {
          "name": "punctuation.definition.string.end.bifrost-rql"
        }
      }
    },
    {
      "name": "string.quoted.double.bifrost-rql",
      "match": "\\\"(?:\\\\.|[^\\\"\\\\])*\\\""
    },
    {
      "name": "punctuation.section.brackets.bifrost-rql",
      "match": "(?:\\((?!\\s*(?:limit|result-detail)\\s)|[)\\[\\]])"
    },
    {
      "name": "variable.parameter.role.bifrost-rql",
      "match": ":(?:args|callee|capture|decorators|depth|field|has|kwargs|left|module|name(?:/regex)?|not[-_]has|not[-_]kind|object|parameter-(?:index|name)|proof|receiver|reference-kinds|right|surface|text/regex|transitive)(?=$|[\\s()\\[\\]])"
    },
    {
      "name": "support.function.wrapper.bifrost-rql",
      "match": "\\b(?:call-input|call-sites-from|call-sites-to|callees|callers|enclosing-decl|file-of|importers-of|imports-of|inside|language|languages|limit|members|not-inside|owner|references-of|result-detail|subtypes|supertypes|used-by|uses|where)\\b"
    },
    {
      "name": "entity.name.type.kind.bifrost-rql",
      "match": "\\b(?:assignment|boolean_literal|call|callable|catch|class|constructor|declaration|decorator|field_access|function|identifier|if|import|lambda|literal|loop|method|null_literal|numeric_literal|return|string_literal|throw)\\b"
    },
    {
      "name": "support.function.predicate.bifrost-rql",
      "match": "\\b(?:capture|has|name(?:/regex)?|not[-_]has|not[-_]kind|text/regex)\\b"
    },
    {
      "name": "meta.hierarchy-depth.bifrost-rql",
      "match": "(:depth\\s+)([0-9]+)(?=\\s)",
      "captures": {
        "1": {
          "name": "variable.parameter.role.bifrost-rql"
        },
        "2": {
          "name": "constant.numeric.integer.decimal.bifrost-rql"
        }
      }
    },
    {
      "name": "meta.hierarchy-transitive.bifrost-rql",
      "match": "(:transitive\\s+)(true)(?=\\s)",
      "captures": {
        "1": {
          "name": "variable.parameter.role.bifrost-rql"
        },
        "2": {
          "name": "constant.language.boolean.true.bifrost-rql"
        }
      }
    },
    {
      "name": "meta.limit.bifrost-rql",
      "match": "(\\(\\s*limit\\s+)([0-9]+)(?=\\s)",
      "captures": {
        "1": {
          "name": "support.function.wrapper.bifrost-rql"
        },
        "2": {
          "name": "constant.numeric.integer.decimal.bifrost-rql"
        }
      }
    },
    {
      "name": "meta.result-detail.bifrost-rql",
      "match": "(\\(\\s*result-detail\\s+)(compact|full)(?=\\s)",
      "captures": {
        "1": {
          "name": "support.function.wrapper.bifrost-rql"
        },
        "2": {
          "name": "constant.language.result-detail.bifrost-rql"
        }
      }
    }
  ]
}
